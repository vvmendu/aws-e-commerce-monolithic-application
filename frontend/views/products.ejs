<%- include('partials/header', {title: title}) %>

<div class="container py-4">
  <h1 class="mb-4"><%= categoryName || title %></h1>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-warning"><%= error %></div>
  <% } %>

  <!-- Filters -->
  <div class="filter-sidebar mb-4">
    <h5>Filter & Sort</h5>
    <form method="GET" class="row g-2">
      <div class="col-md-3">
        <select name="sort_by" class="form-select">
          <option value="created_at" <%= filters.sort_by === 'created_at' ? 'selected' : '' %>>Newest</option>
          <option value="price" <%= filters.sort_by === 'price' ? 'selected' : '' %>>Price</option>
          <option value="rating" <%= filters.sort_by === 'rating' ? 'selected' : '' %>>Rating</option>
          <option value="name" <%= filters.sort_by === 'name' ? 'selected' : '' %>>Name</option>
        </select>
      </div>
      <div class="col-md-2">
        <select name="sort_order" class="form-select">
          <option value="desc" <%= filters.sort_order === 'desc' ? 'selected' : '' %>>Desc</option>
          <option value="asc" <%= filters.sort_order === 'asc' ? 'selected' : '' %>>Asc</option>
        </select>
      </div>
      <div class="col-md-2">
        <input type="number" name="min_price" class="form-control" placeholder="Min Price" value="<%= filters.min_price %>">
      </div>
      <div class="col-md-2">
        <input type="number" name="max_price" class="form-control" placeholder="Max Price" value="<%= filters.max_price %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Apply</button>
      </div>
    </form>
  </div>

  <% if (products && products.length > 0) { %>
  <div class="row g-3">
    <% products.forEach(product => { %>
    <div class="col-6 col-md-3">
      <div class="card product-card position-relative">
        <% if (product.is_featured) { %><span class="badge bg-primary product-badge">Featured</span><% } %>
        <% if (product.is_bestseller) { %><span class="badge bg-warning text-dark product-badge">Best Seller</span><% } %>
        <img src="<%= product.images && product.images[0] ? product.images[0].image_url : 'https://via.placeholder.com/300x250?text=' + encodeURIComponent(product.name) %>"
             class="card-img-top product-card-img" alt="<%= product.name %>">
        <div class="card-body">
          <h6 class="card-title"><%= product.name %></h6>
          <% if (product.brand) { %><small class="text-muted"><%= product.brand %></small><% } %>
          <p class="mb-1 product-price">$<%= product.sale_price ? product.sale_price.toFixed(2) : product.price.toFixed(2) %></p>
          <% if (product.sale_price) { %><small class="product-sale-price">$<%= product.price.toFixed(2) %></small><% } %>
          <div class="product-rating mb-2">
            <% for(let i=1;i<=5;i++) { %><i class="fas fa-star<%= i <= Math.round(product.rating_avg) ? '' : '-half-alt' %>"></i><% } %>
            <small class="text-muted">(<%= product.rating_count %>)</small>
          </div>
          <% if (product.in_stock) { %>
            <span class="stock-status in-stock">In Stock</span>
          <% } else { %>
            <span class="stock-status out-of-stock">Out of Stock</span>
          <% } %>
          <div class="d-flex gap-2 mt-2">
            <a href="/products/<%= product.slug %>" class="btn btn-sm btn-outline-primary flex-fill">View</a>
            <% if (product.in_stock) { %>
              <button class="btn btn-sm btn-add-to-cart flex-fill" onclick="addToCart(<%= product.id %>)">Add</button>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- Pagination -->
  <% if (pagination.pages > 1) { %>
  <nav class="mt-4">
    <ul class="pagination justify-content-center">
      <% if (pagination.has_prev) { %><li class="page-item"><a class="page-link" href="?page=<%= pagination.page - 1 %>">Previous</a></li><% } %>
      <% for(let i=1; i<=pagination.pages; i++) { %>
        <li class="page-item <%= i === pagination.page ? 'active' : '' %>"><a class="page-link" href="?page=<%= i %>"><%= i %></a></li>
      <% } %>
      <% if (pagination.has_next) { %><li class="page-item"><a class="page-link" href="?page=<%= pagination.page + 1 %>">Next</a></li><% } %>
    </ul>
  </nav>
  <% } %>

  <% } else { %>
  <div class="text-center py-5">
    <i class="fas fa-search fa-3x text-muted mb-3"></i>
    <h4>No products found</h4>
    <p class="text-muted">Try adjusting your filters or search terms.</p>
  </div>
  <% } %>
</div>

<%- include('partials/footer') %>
