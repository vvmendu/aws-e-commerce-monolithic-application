<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/"><i class="fas fa-shopping-bag me-2"></i>ShopNow</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/electronics">Electronics</a></li>
        <li class="nav-item"><a class="nav-link" href="/household">Household</a></li>
        <li class="nav-item"><a class="nav-link" href="/books">Books</a></li>
        <li class="nav-item"><a class="nav-link" href="/clothing">Clothing</a></li>
        <li class="nav-item"><a class="nav-link" href="/sports">Sports</a></li>
        <li class="nav-item"><a class="nav-link" href="/bestsellers">Best Sellers</a></li>
      </ul>
      <form class="d-flex me-3" action="/search" method="GET">
        <input class="form-control me-2" type="search" name="q" placeholder="Search products..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
        <button class="btn btn-outline-light" type="submit"><i class="fas fa-search"></i></button>
      </form>
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" href="/cart"><i class="fas fa-shopping-cart"></i> Cart
            <% if (cartCount > 0) { %><span class="badge bg-warning text-dark"><%= cartCount %></span><% } %>
          </a>
        </li>
        <% if (user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><%= user.first_name %></a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/auth/profile">My Profile</a></li>
              <li><a class="dropdown-item" href="/orders">My Orders</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<main><%- body %></main>

<footer class="bg-dark text-light py-4 mt-5">
  <div class="container">
    <div class="row">
      <div class="col-md-4"><h5>ShopNow</h5><p>Your one-stop e-commerce platform for all your needs.</p></div>
      <div class="col-md-4"><h5>Quick Links</h5>
        <ul class="list-unstyled">
          <li><a href="/about" class="text-light">About Us</a></li>
          <li><a href="/contact" class="text-light">Contact</a></li>
          <li><a href="/terms" class="text-light">Terms of Service</a></li>
          <li><a href="/privacy" class="text-light">Privacy Policy</a></li>
        </ul>
      </div>
      <div class="col-md-4"><h5>Connect With Us</h5>
        <div class="d-flex gap-3 fs-4">
          <a href="#" class="text-light"><i class="fab fa-facebook"></i></a>
          <a href="#" class="text-light"><i class="fab fa-twitter"></i></a>
          <a href="#" class="text-light"><i class="fab fa-instagram"></i></a>
        </div>
      </div>
    </div>
    <hr><p class="text-center mb-0">&copy; 2026 ShopNow. All rights reserved.</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/cart.js"></script>
</body>
</html>
