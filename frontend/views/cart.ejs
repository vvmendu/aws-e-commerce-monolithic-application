<%- include('partials/header', {title: title}) %>
<div class="container py-4">
  <h1 class="mb-4">Shopping Cart</h1>
  <% if (typeof error !== 'undefined' && error) { %><div class="alert alert-warning"><%= error %></div><% } %>

  <% if (items && items.length > 0) { %>
  <div class="row">
    <div class="col-md-8">
      <% items.forEach(item => { %>
      <div class="cart-item d-flex align-items-center">
        <img src="<%= item.product && item.product.images && item.product.images[0] ? item.product.images[0].image_url : 'https://via.placeholder.com/100?text=Product' %>"
             class="cart-item-img me-3" alt="<%= item.product ? item.product.name : 'Product' %>">
        <div class="flex-grow-1">
          <h6><%= item.product ? item.product.name : 'Unknown Product' %></h6>
          <p class="text-muted mb-1">Qty: <%= item.quantity %></p>
          <p class="product-price mb-0">$<%= item.subtotal ? item.subtotal.toFixed(2) : '0.00' %></p>
        </div>
        <form method="POST" action="/cart/remove/<%= item.id %>">
          <button type="submit" class="btn btn-sm btn-outline-danger ms-3">
            <i class="fas fa-trash"></i>
          </button>
        </form>
      </div>
      <% }) %>
    </div>
    <div class="col-md-4">
      <div class="cart-summary">
        <h4>Order Summary</h4>
        <hr>
        <div class="d-flex justify-content-between mb-2">
          <span>Subtotal (<%= count %> items)</span>
          <strong>$<%= typeof total === 'number' ? total.toFixed(2) : total %></strong>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span>Shipping</span>
          <span><%= total >= 50 ? 'FREE' : '$5.99' %></span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span>Tax (8%)</span>
          <span>$<%= (total * 0.08).toFixed(2) %></span>
        </div>
        <hr>
        <div class="d-flex justify-content-between mb-3">
          <strong>Total</strong>
          <strong>$<%= (total + (total >= 50 ? 0 : 5.99) + total * 0.08).toFixed(2) %></strong>
        </div>
        <a href="/checkout" class="btn btn-warning w-100 btn-lg">Proceed to Checkout</a>
        <a href="/" class="btn btn-outline-secondary w-100 mt-2">Continue Shopping</a>
      </div>
    </div>
  </div>
  <% } else { %>
  <div class="text-center py-5">
    <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
    <h4>Your cart is empty</h4>
    <a href="/" class="btn btn-primary mt-3">Start Shopping</a>
  </div>
  <% } %>
</div>
<%- include('partials/footer') %>
